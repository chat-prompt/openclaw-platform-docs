---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'OpenClaw 플랫폼팀 전략 워크스페이스' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | OpenClaw 플랫폼팀</title>
  <meta name="description" content={description} />
  <script is:inline>
    // 깜빡임 방지: 페이지 로드 전에 테마 적용
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
    })();
  </script>
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">
        <span class="logo-icon">🚀</span>
        <span>OpenClaw 플랫폼팀</span>
      </a>
      <nav class="site-nav">
        <a href="/openclaw-platform">플랫폼</a>
        <a href="/openclaw-content">콘텐츠</a>
        <button class="theme-toggle" id="theme-toggle" aria-label="테마 전환">🌙</button>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>🚀 OpenClaw 플랫폼팀 — 오픈클로 = 지피터스</p>
  </footer>

  <script is:inline>
    (function() {
      const btn = document.getElementById('theme-toggle');
      function update() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        btn.textContent = isDark ? '☀️' : '🌙';
      }
      update();
      btn.addEventListener('click', function() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        }
        update();
      });
    })();
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
