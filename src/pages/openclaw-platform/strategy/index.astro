---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allDocs = await getCollection('openclaw-platform');
const docs = allDocs
  .filter(d => !d.slug.startsWith('meetings/') && !d.slug.startsWith('duckhu-archive/') && !d.slug.startsWith('reports/') && d.slug.toLowerCase() !== 'readme')
  .sort((a, b) => a.slug.localeCompare(b.slug));
---

<BaseLayout title="전략 문서 — openclaw-platform">
  <div class="list-page">
    <div class="back"><a href="/openclaw-platform">← openclaw-platform</a></div>
    <header class="list-header">
      <h1>📝 전략 문서</h1>
      <p>{docs.length}편 — 개요, 채널전략, 봇코칭, KPI, 강의, Q&A 등</p>
    </header>
    <div class="list-grid">
      {docs.map((doc) => (
        <a href={`/openclaw-platform/${doc.slug}`} class="list-card">
          <h3 class="card-title">{doc.data.title}</h3>
          {doc.data.date && <span class="card-date">{doc.data.date}</span>}
          {doc.data.description && <p class="card-desc">{doc.data.description}</p>}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .list-page { max-width: 800px; margin: 0 auto; padding: 0 24px 80px; }
  .back { padding-top: 24px; }
  .back a { font-size: 14px; color: var(--accent); text-decoration: none; font-weight: 600; }
  .back a:hover { text-decoration: underline; }
  .list-header { text-align: center; padding: 32px 0 24px; }
  .list-header h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
  .list-header p { font-size: 15px; color: var(--text-secondary); }
  .list-grid { display: flex; flex-direction: column; gap: 10px; }
  .list-card {
    display: block; padding: 16px 20px;
    background: var(--bg-card); border: 1px solid var(--border-card);
    border-radius: 12px; text-decoration: none; transition: all 0.2s;
  }
  .list-card:hover { border-color: var(--accent); transform: translateY(-1px); }
  .card-title { font-size: 16px; font-weight: 700; color: var(--text-primary); }
  .card-date { font-size: 12px; color: var(--text-muted); margin-top: 2px; display: inline-block; }
  .card-desc { font-size: 13px; color: var(--text-secondary); margin-top: 4px; line-height: 1.5; }
</style>
