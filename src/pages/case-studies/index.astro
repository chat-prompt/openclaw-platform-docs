---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('case-studies')).sort(
  (a, b) => a.data.episode - b.data.episode
);

const folderDescriptions: Record<string, string> = {
  'handbook': '3/27 무료웨비나 후기리워드 — 워크스페이스, 보안, 영혼, 팀워크. 봇을 잘 키우는 핵심 가이드 4편.',
  'bbopters': '4/3 무료웨비나 후기리워드 — 봇 4마리가 3대 머신에서 팀이 되기까지. 창단, Slack 연동, 설정 삽질기.',
  'claude-code': '4/12 AI토크 「뽀피터스팀 생존기 — 구독 막히고, 말투는 T짝이 되고」 후기리워드. 구독 뽕뽑기부터 슬랙 봇 팀 세팅까지.',
  'raising-one-bot': '4/10 박정기 웨비나 「NanoClaw vs OpenClaw」 후기리워드 — 도구가 아니라 팀원으로, 한 마리 잘 키우는 6편 시리즈.',
};

const folderMap = new Map<string, { label: string; description: string; count: number; locked: boolean }>();
for (const post of posts) {
  const folder = post.slug.split('/')[0];
  const existing = folderMap.get(folder);
  if (existing) {
    existing.count++;
  } else {
    folderMap.set(folder, {
      label: post.data.category || folder,
      description: folderDescriptions[folder] || '',
      count: 1,
      locked: !!post.data.token,
    });
  }
}
const folders = [...folderMap.entries()];
---

<BaseLayout title="후기리워드 자료집">
  <div class="list-page">
    <header class="list-header">
      <h1>🏆 후기리워드 자료집</h1>
      <p>봇을 키우고 팀을 만든 실전 이야기. 삽질과 설정, 그리고 교훈.</p>
    </header>

    <div class="folder-grid">
      {folders.map(([folder, info]) => (
        <a href={`/case-studies/${folder}`} class="folder-card">
          <span class="folder-icon">{info.locked ? '🔒' : '📁'}</span>
          <div class="folder-body">
            <h2 class="folder-title">{info.label}</h2>
            {info.description && <p class="folder-desc">{info.description}</p>}
            <p class="folder-count">{info.count}편</p>
          </div>
          <span class="folder-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .list-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .list-header {
    text-align: center;
    padding: 60px 0 40px;
  }

  .list-header h1 {
    font-size: 32px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .list-header p {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .folder-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .folder-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .folder-card:hover {
    border-color: #D4802A;
    box-shadow: 0 4px 24px rgba(212, 128, 42, 0.12);
    transform: translateY(-1px);
  }

  .folder-icon {
    font-size: 28px;
    flex-shrink: 0;
  }

  .folder-body {
    flex: 1;
  }

  .folder-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .folder-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .folder-count {
    font-size: 13px;
    color: var(--text-muted);
  }

  .folder-arrow {
    font-size: 18px;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .folder-card:hover .folder-arrow {
    transform: translateX(3px);
  }
</style>
