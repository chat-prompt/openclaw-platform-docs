---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('case-studies')).sort(
  (a, b) => a.data.episode - b.data.episode
);

const folderMeta: Record<string, { order: number; date: string; description: string }> = {
  'handbook':        { order: 1, date: '2026-03-27', description: '3/27 무료웨비나 후기리워드 — 워크스페이스, 보안, 영혼, 팀워크. 봇을 잘 키우는 핵심 가이드 4편.' },
  'bbopters':        { order: 2, date: '2026-04-03', description: '4/3 무료웨비나 후기리워드 — 봇 4마리가 3대 머신에서 팀이 되기까지. 창단, Slack 연동, 설정 삽질기.' },
  'raising-one-bot': { order: 3, date: '2026-04-10', description: '4/10 박정기 웨비나 「NanoClaw vs OpenClaw」 후기리워드 — 도구가 아니라 팀원으로, 한 마리 잘 키우는 6편 시리즈.' },
  'claude-code':     { order: 4, date: '2026-04-12', description: '4/12 AI토크 「뽀피터스팀 생존기 — 구독 막히고, 말투는 T짝이 되고」 후기리워드. 구독 뽕뽑기부터 슬랙 봇 팀 세팅까지.' },
  'multi-agent':     { order: 5, date: '2026-04-25', description: '4/25 GPTers 밋업 후기리워드 — Slack × Claude CLI로 멀티에이전트 키우는 4편 시리즈. 1마리·2마리·N대 머신 셋업과 작동법(멘션·sessions_send·위임 spawn) 한 묶음.' },
};

const folderGroups = new Map<string, typeof posts>();
for (const post of posts) {
  const folder = post.slug.split('/')[0];
  const arr = folderGroups.get(folder) ?? [];
  arr.push(post);
  folderGroups.set(folder, arr);
}

const folders = [...folderGroups.entries()]
  .map(([folder, folderPosts]) => {
    const meta = folderMeta[folder];
    return {
      folder,
      order: meta?.order ?? 999,
      label: folderPosts[0].data.category || folder,
      description: meta?.description ?? '',
      count: folderPosts.length,
      locked: folderPosts.some(p => !!p.data.token),
    };
  })
  .sort((a, b) => a.order - b.order);
---

<BaseLayout title="후기리워드 자료집">
  <div class="list-page">
    <header class="list-header">
      <h1>🏆 후기리워드 자료집</h1>
      <p>봇을 키우고 팀을 만든 실전 이야기. 삽질과 설정, 그리고 교훈.</p>
    </header>

    <div class="folder-grid">
      {folders.map((info) => (
        <a href={`/case-studies/${info.folder}`} class="folder-card">
          <span class="folder-icon">{info.locked ? '🔒' : '📁'}</span>
          <div class="folder-body">
            <h2 class="folder-title">
              <span class="folder-series">#{info.order}</span> {info.label}
            </h2>
            {info.description && <p class="folder-desc">{info.description}</p>}
            <p class="folder-count">{info.count}편</p>
          </div>
          <span class="folder-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .list-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .list-header {
    text-align: center;
    padding: 60px 0 40px;
  }

  .list-header h1 {
    font-size: 32px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .list-header p {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .folder-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .folder-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .folder-card:hover {
    border-color: #D4802A;
    box-shadow: 0 4px 24px rgba(212, 128, 42, 0.12);
    transform: translateY(-1px);
  }

  .folder-icon {
    font-size: 28px;
    flex-shrink: 0;
  }

  .folder-body {
    flex: 1;
  }

  .folder-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .folder-series {
    color: #D4802A;
    font-weight: 800;
    margin-right: 4px;
  }

  .folder-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .folder-count {
    font-size: 13px;
    color: var(--text-muted);
  }

  .folder-arrow {
    font-size: 18px;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .folder-card:hover .folder-arrow {
    transform: translateX(3px);
  }
</style>
