---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeriesGate from '../../components/SeriesGate.astro';

const guides = (await getCollection('setup-guides')).sort((a, b) => a.data.episode - b.data.episode);
const seriesToken = guides.find(g => g.data.token)?.data.token || '';
---

<BaseLayout title="OpenClaw 셋업 레시피">
  <div class="list-page">
    <header class="list-header">
      <span class="track-badge">📚 단편 레시피</span>
      <h1>🧰 OpenClaw 셋업 레시피</h1>
      <p>필요한 기능만 골라보는 단편 가이드 모음 — Claw 비교, Slack 세부, Syncthing, Google 연동, 마이그레이션</p>
    </header>

    <a href="/multi-agent" class="cross-track-banner">
      <span class="cross-track-icon">🤖</span>
      <span class="cross-track-text">
        <strong>처음 OpenClaw 셋업이라면 → 멀티 에이전트 코어 시리즈</strong>
        <span class="cross-track-sub">ep.1부터 한 호흡으로 보는 코어 시리즈 (4/25 밋업 자료)</span>
      </span>
    </a>

    <a href="https://bbojjak-library.gpters.org" class="cross-link-banner" target="_blank" rel="noopener">
      <span class="cross-link-icon">🐈‍⬛</span>
      <span class="cross-link-text">
        <strong>뽀짝이의 수업 & 업무일지 보러가기</strong>
        <span class="cross-link-sub">AI스터디 수업 시리즈 · 업무일지 · Q&A →</span>
      </span>
    </a>

    {seriesToken ? (
      <SeriesGate token={seriesToken} seriesKey="setup-guides-series-token">
        <div class="list-grid">
          {guides.map((guide) => (
            <a href={`/setup-guides/${guide.slug}`} class="list-card" style={guide.data.accentColor ? `--card-accent: ${guide.data.accentColor}` : ''}>
              <div class="card-header">
                <span class="card-episode" style={guide.data.accentColor ? `color: ${guide.data.accentColor}` : ''}>가이드 #{guide.data.episode}</span>
                {guide.data.publishedAt && (
                  <span class="card-date">{guide.data.publishedAt.replace(/^\d{4}-/, '')}</span>
                )}
              </div>
              <h2 class="card-title">{guide.data.title}</h2>
              {guide.data.description && (
                <p class="card-desc">{guide.data.description}</p>
              )}
            </a>
          ))}
        </div>
      </SeriesGate>
    ) : (
      <div class="list-grid">
        {guides.map((guide) => (
          <a href={`/setup-guides/${guide.slug}`} class="list-card" style={guide.data.accentColor ? `--card-accent: ${guide.data.accentColor}` : ''}>
            <div class="card-header">
              <span class="card-episode" style={guide.data.accentColor ? `color: ${guide.data.accentColor}` : ''}>가이드 #{guide.data.episode}</span>
              {guide.data.publishedAt && (
                <span class="card-date">{guide.data.publishedAt.replace(/^\d{4}-/, '')}</span>
              )}
            </div>
            <h2 class="card-title">{guide.data.title}</h2>
            {guide.data.description && (
              <p class="card-desc">{guide.data.description}</p>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .list-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .list-header {
    text-align: center;
    padding: 60px 0 40px;
  }

  .track-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    color: #E8590C;
    background: color-mix(in srgb, #E8590C 12%, transparent);
    padding: 4px 12px;
    border-radius: 999px;
    letter-spacing: 0.04em;
    margin-bottom: 16px;
  }

  .list-header h1 {
    font-size: 32px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .list-header p {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .cross-track-banner {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    margin-bottom: 16px;
    background: color-mix(in srgb, #8B5CF6 6%, var(--bg-card));
    border: 1px solid color-mix(in srgb, #8B5CF6 30%, var(--border-card));
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cross-track-banner:hover {
    border-color: #8B5CF6;
    background: color-mix(in srgb, #8B5CF6 10%, var(--bg-card));
  }

  .cross-track-icon {
    font-size: 28px;
    flex-shrink: 0;
  }

  .cross-track-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cross-track-text strong {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .cross-track-sub {
    font-size: 13px;
    color: var(--text-secondary);
  }

  .list-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .list-card {
    display: block;
    padding: 20px 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .list-card:hover {
    border-color: var(--card-accent, var(--accent));
    box-shadow: 0 4px 24px rgba(91, 141, 190, 0.12);
    transform: translateY(-1px);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .card-episode {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
  }

  .card-date {
    font-size: 12px;
    color: var(--text-muted);
  }

  .card-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .card-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .cross-link-banner {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    margin-bottom: 24px;
    background: var(--bg-card);
    border: 1px dashed var(--border-card);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cross-link-banner:hover {
    border-color: #6B9B7B;
    background: color-mix(in srgb, var(--bg-card) 90%, #6B9B7B);
  }

  .cross-link-icon {
    font-size: 28px;
    flex-shrink: 0;
  }

  .cross-link-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cross-link-text strong {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .cross-link-sub {
    font-size: 13px;
    color: var(--text-secondary);
  }
</style>
